{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "YomuGo API v1",
    "description": "Colección para la API REST de Yomu (NestJS).\n\n**Variables:** `apiHost`, `apiPort`, `accessToken`, `userId` (tras login/register), `categoryId`, `wordId`.\n\nLogin usa `identifier` (usuario o email). Registro requiere `username`, `email`, `password`. Para el primer admin: registrate y en la BD cambia `role` a `ADMIN` (ver README).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "apiHost",
      "value": "localhost"
    },
    {
      "key": "apiPort",
      "value": "3000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "categoryId",
      "value": "7"
    },
    {
      "key": "userId",
      "value": "1"
    },
    {
      "key": "wordId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "00 - Health / Locales",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://{{apiHost}}:{{apiPort}}/api/v1/health",
              "protocol": "http",
              "host": ["{{apiHost}}"],
              "port": "{{apiPort}}",
              "path": ["api", "v1", "health"]
            },
            "description": "Comprobación del servidor."
          },
          "response": []
        },
        {
          "name": "Locales soportados",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://{{apiHost}}:{{apiPort}}/api/v1/locales",
              "protocol": "http",
              "host": ["{{apiHost}}"],
              "port": "{{apiPort}}",
              "path": ["api", "v1", "locales"]
            },
            "description": "Devuelve ['es', 'pt']."
          },
          "response": []
        }
      ]
    },
    {
      "name": "01 - Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  if ([200, 201].includes(pm.response.code)) {",
                  "    const j = pm.response.json();",
                  "    if (j.success && j.data && j.data.token) {",
                  "      pm.collectionVariables.set('accessToken', j.data.token);",
                  "      if (j.data.user && j.data.user.id) {",
                  "        pm.collectionVariables.set('userId', String(j.data.user.id));",
                  "      }",
                  "    }",
                  "  }",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demo\",\n  \"email\": \"demo@example.com\",\n  \"password\": \"secret12\",\n  \"preferredLocale\": \"es\"\n}"
            },
            "url": {
              "raw": "http://{{apiHost}}:{{apiPort}}/api/v1/auth/register",
              "protocol": "http",
              "host": ["{{apiHost}}"],
              "port": "{{apiPort}}",
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "`preferredLocale` opcional: `es` | `pt`."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const j = pm.response.json();",
                  "    if (j.success && j.data && j.data.token) {",
                  "      pm.collectionVariables.set('accessToken', j.data.token);",
                  "      if (j.data.user && j.data.user.id) {",
                  "        pm.collectionVariables.set('userId', String(j.data.user.id));",
                  "      }",
                  "    }",
                  "  }",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"demo\",\n  \"password\": \"secret12\"\n}"
            },
            "url": {
              "raw": "http://{{apiHost}}:{{apiPort}}/api/v1/auth/login",
              "protocol": "http",
              "host": ["{{apiHost}}"],
              "port": "{{apiPort}}",
              "path": ["api", "v1", "auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Me (usuario actual)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://{{apiHost}}:{{apiPort}}/api/v1/auth/me",
              "protocol": "http",
              "host": ["{{apiHost}}"],
              "port": "{{apiPort}}",
              "path": ["api", "v1", "auth", "me"]
            }
          },
          "response": []
        }
      ]
    },
